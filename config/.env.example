# Tushare API Token 配置文件
# 使用方法:
#   1. 复制此文件为 .env:  cp config/.env.example .env
#   2. 将 your_token_here 替换为你的真实 token
#   3. 启动时自动加载（或在终端执行: export TUSHARE_TOKEN='your_token_here'）
#
# 获取 token: https://tushare.pro/ 注册并获取
# 积分与权限对照: https://tushare.pro/document/1?doc_id=108

TUSHARE_TOKEN = your_token_here
